<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="../../props/common.props" />
  
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsTestProject>true</IsTestProject>
    <RootNamespace>Specs</RootNamespace>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <OutputType>library</OutputType>
    <NoWarn>RS1038;RS1041</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOsPlatform('Windows'))">
    <DefineConstants>Is_Windows</DefineConstants>
  </PropertyGroup>

  <ItemGroup Label="Project under test">
    <ProjectReference Include="../../src/DotNetProjectFile.Analyzers/DotNetProjectFile.Analyzers.csproj" />
    <ProjectReference Include="../Benchmarks/Benchmarks.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Buildalyzer" Version="9.0.0" />
    <PackageReference Include="Microsoft.CodeAnalysis" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Common" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="5.3.0" />
    <PackageReference Include="Microsoft.IO.Redist" Version="6.1.3" NoWarn="NU1701" />
  </ItemGroup>

  <ItemGroup Label="Test tools">
    <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    <PackageReference Include="CodeAnalysis.TestTools" Version="5.0.0" />
    <PackageReference Include="NuGet.Common" Version="7.3.1" />
    <PackageReference Include="NuGet.Frameworks" Version="7.3.1" />
    <PackageReference Include="NuGet.Packaging" Version="7.3.1" />
    <PackageReference Include="NUnit" Version="4.6.0" />
    <PackageReference Include="Verify" Version="31.16.2" />
    <PackageReference Include="Verify.NUnit" Version="31.16.2" />
  </ItemGroup>

  <ItemGroup Label="Build tools">
    <PackageReference PrivateAssets="all" Include="coverlet.collector" Version="10.0.0" />
    <PackageReference PrivateAssets="all" Include="Microsoft.Build.Tasks.Core" Version="18.4.0" />
    <PackageReference PrivateAssets="all" Include="Microsoft.NET.Test.Sdk" Version="18.5.1" />
    <PackageReference PrivateAssets="all" Include="NUnit3TestAdapter" Version="6.2.0" />
  </ItemGroup>

  <ItemGroup Label="Test projects">
    <None Visible="true" Include="../../projects/*/*.csproj" Link="Projects/C#/%(Filename)%(Extension)" />
    <None Visible="true" Include="../../projects/*/*.vbproj" Link="Projects/VB/%(Filename)%(Extension)" />
    <None Visible="true" Include="../../projects/*/*.resx" Link="Projects/RESX/%(Filename)%(Extension)" />
    <None Visible="true" Include="../../projects/*/*.props" Link="Projects/Props/%(Directory)/%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup Label="Analyzers">
    <PackageReference PrivateAssets="all" Include="AwesomeAssertions.Analyzers" Version="9.0.8" />
    <PackageReference PrivateAssets="all" Include="NUnit.Analyzers" Version="4.13.0" />
  </ItemGroup>

</Project>
