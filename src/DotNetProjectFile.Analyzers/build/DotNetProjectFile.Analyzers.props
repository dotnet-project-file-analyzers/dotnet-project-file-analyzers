<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <Import Project="$(MSBuildThisFileDirectory)AdditionalFiles.props" />
  <Import Project="$(MSBuildThisFileDirectory)CompilerVisible.props" />

  <PropertyGroup>
    <SonarQubeIntegration>true</SonarQubeIntegration>
    <IsDotNetProjectFileSdk Condition="$(MSBuildProjectFile) == '.net.csproj'">true</IsDotNetProjectFileSdk>
  </PropertyGroup>

  <!--
    Explicitly include .globalconfig file(s)
    
    For some strange reason, .globalconfig seems sometimes not be included
    automatically. As we advise to configure the severity of rules there, the
    least we can do is ensure that those preferences are taken into account.
    -->
  <ItemGroup>
    <GlobalAnalyzerConfigFiles
      Include="$([MSBuild]::GetPathOfFileAbove('.globalconfig', '$(MSBuildThisFileDirectory)'))"
      Exclude="$(GlobalAnalyzerConfigFiles)"
      Visible="false" />
  </ItemGroup>

  <!-- Extend the additional files for the .net.csproj -->
  <Import
     Condition="$(IsDotNetProjectFileSdk) == 'true'"
     Project="$(MSBuildThisFileDirectory)AdditionalFiles.Sdk.props" />

  <Import
     Condition="$(IsDotNetProjectFileSdk) == 'true'"
     Project="$(MSBuildThisFileDirectory)DotNetProjectFile.Analyzers.Sdk.props" />


  <!--
    Remove what is most likely in the .gitignore
    
    It is put here, because both the .net.csproj additonal files as the regular
    set has been added, and can therfor safely be filtered.
    -->
  <ItemGroup>
    <AdditionalFiles Remove="**/bin/**" />
    <AdditionalFiles Remove="**/obj/**" />
    <AdditionalFiles Remove="**/.git/**" />
    <AdditionalFiles Remove="**/.nuget/**" />
    <AdditionalFiles Remove="**/.vs/**" />
  </ItemGroup>


</Project>
